# .gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Trained model weights (large binary files — store on shared drive or release)
models/*.zip
models/*.pt
models/*.pth
# Exception: keep the best model if small enough
# !models/best_model.zip

# Experiment results CSVs (generated — do not commit raw data)
results/*.csv

# Videos and GIFs (large — do not commit)
videos/*.mp4
videos/*.gif
videos/*.avi

# Report PDFs (share via Google Drive or upload separately)
report/*.pdf
report/*.pptx

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE settings
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
tensorboard_logs/
logs/

# Pytest / coverage
.pytest_cache/
htmlcov/
.coverage
